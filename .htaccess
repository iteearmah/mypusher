RewriteEngine On

# 1. Catch WebSocket Upgrade Requests (both ws and wss) and proxy to your Node.js Port.
#    Apache terminates TLS at the edge, while the internal Node.js server speaks
#    plain (non-TLS) WebSocket. Therefore, even for secure (wss) client
#    connections, the backend MUST be addressed as ws:// — using wss:// here
#    would make Apache try a TLS handshake against a non-TLS backend and return
#    an Internal Server Error (500).
RewriteCond %{HTTP:Upgrade} websocket [NC]
RewriteCond %{HTTP:Connection} upgrade [NC]
RewriteRule ^(.*)$ ws://127.0.0.1:3000/$1 [P,L]

# 2. Proxy the Node.js HTTP API endpoints (e.g. /message, /pusher/auth) to the
#    internal port 3000. The leading "/?" makes the rule robust regardless of
#    whether mod_rewrite passes the path with or without a leading slash in this
#    per-directory (.htaccess) context. We exclude WebSocket upgrades (already
#    handled by rule 1) so this only catches plain HTTP API requests.
RewriteCond %{HTTP:Upgrade} !=websocket [NC]
RewriteRule ^/?(message|pusher/auth)$ http://127.0.0.1:3000/$1 [P,L]
