RewriteEngine On

# 1a. Catch Secure WebSocket Upgrade Requests (wss) over HTTPS and Proxy to your Node.js Port
RewriteCond %{HTTP:Upgrade} websocket [NC]
RewriteCond %{HTTP:Connection} upgrade [NC]
RewriteCond %{HTTPS} =on [NC,OR]
RewriteCond %{HTTP:X-Forwarded-Proto} =https [NC]
RewriteRule ^(.*)$ wss://127.0.0.1:3000/$1 [P,L]

# 1b. Catch standard WebSocket Upgrade Requests (ws) and Proxy to your Node.js Port
RewriteCond %{HTTP:Upgrade} websocket [NC]
RewriteCond %{HTTP:Connection} upgrade [NC]
RewriteRule ^(.*)$ ws://127.0.0.1:3000/$1 [P,L]

# 2. Fallback for your standard HTTP/HTTPS API traffic (Optional)
# RewriteRule ^(.*)$ http://127.0.0 [P,L]