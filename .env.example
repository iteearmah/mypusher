# Server configuration
PORT=3000

# Pusher credentials
# These are used for compatibility with Pusher client libraries.
# Since this is a self-hosted server, you can use any values, but they must match what your client uses.
PUSHER_APP_ID=YOUR_APP_ID
PUSHER_APP_KEY=YOUR_APP_KEY
PUSHER_APP_SECRET=YOUR_APP_SECRET
PUSHER_APP_CLUSTER=mt1

# Monitor Dashboard Authentication
MONITOR_USERNAME=admin
MONITOR_PASSWORD=password

# Security: Comma-separated list of allowed origins (e.g., http://localhost:3000, *.example.com)
# If left empty, allowed_origins.json will be used if it exists.
ALLOWED_ORIGINS=

# Optional: Self-pinging configuration (useful for keeping free hosting like Render awake)
SELF_PING_URL=
SELF_PING_INTERVAL=840000
